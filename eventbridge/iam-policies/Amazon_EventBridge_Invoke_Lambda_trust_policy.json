{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "TrustEventBridgeService",
            "Effect": "Allow",
            "Principal": {
                "Service": "events.amazonaws.com"
            },
            "Action": "sts:AssumeRole",
            "Condition": {
                "StringEquals": {
                    "aws:SourceAccount": "744640651507",
                    "aws:SourceArn": "arn:aws:events:us-east-1:744640651507:rule/Dev-Trigger-SFTP-Malware-Router"
                }
            }
        }
    ]
}