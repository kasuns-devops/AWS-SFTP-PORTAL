                        "arn:aws:iam::744640651507:user/kasuns@champsoft.com",
                        "arn:aws:iam::744640651507:user/umesh@champsoft.com",
                        "arn:aws:iam::744640651507:user/naduni@champsoft.com"
                    ]
                }
            }
        }
